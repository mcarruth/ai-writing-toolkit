}

# --- Subcommand: exec-comms ---

cmd_exec_comms() {
    local usage="Usage: ait exec-comms <message-or-file> [--context <file>]... [--output <file>]

  <message-or-file>  Your draft message or path to a file (quote multi-word messages)
  -c, --context      Inject a context file (repeatable)
  -o, --output       Write output to file (default: stdout)

Examples:
  ait exec-comms \"We had an outage today for 55 minutes due to memory issues\"
  ait exec-comms draft-email.txt -c roadmap.md -o exec-update.md"

    parse_context_and_output "$@" || { echo "$usage" >&2; exit 1; }
    if [[ -z "$POSITIONAL" ]]; then echo "$usage" >&2; exit 1; fi

    # Detect whether we need the LLM to generate a filename:
    # only when input is raw text (not a file) and no explicit -o was given
    local need_autoname=false
    if [[ ! -f "$POSITIONAL" ]] && [[ -z "$OUTPUT_FILE" ]] && [[ -n "${AIT_OUTPUT_DIR:-}" ]]; then
        need_autoname=true
    fi

    local auto_name="$POSITIONAL"
    [[ -f "$POSITIONAL" ]] && auto_name="$(basename "$POSITIONAL" .md)"
    resolve_output "exec-comms" "$auto_name"

    local message
    if [[ -f "$POSITIONAL" ]]; then
        message=$(cat "$POSITIONAL")
    else
        message="$POSITIONAL"
    fi

    load_skill "exec-comms"
    local prompt="${SHARED_CONTENT}

---

${SKILL_CONTENT}

---

Engineer's draft communication:

${message}"

    prompt=$(append_context "$prompt" "${CONTEXT_FILES[@]+"${CONTEXT_FILES[@]}"}")

    if $need_autoname; then
        prompt="${prompt}

---

IMPORTANT: This is an async task. Begin your response with a filename on its own line in this exact format:
FILENAME: kebab-case-name
The filename should be 3-5 kebab-case words that describe what this communication is about (e.g. outage-memory-failover-q2, latency-regression-resolved, security-signoff-delayed). Then output a blank line, then your FIR response. Do not ask for clarification or confirmation."

        local raw suggested content
        raw=$(capture_llm "$prompt")
        suggested=$(printf '%s\n' "$raw" | head -1 | sed 's/^FILENAME:[[:space:]]*//')
        content=$(printf '%s\n' "$raw" | sed '1,2d')

        # Fallback if LLM didn't follow the format
        if [[ ! "$suggested" =~ ^[a-z0-9-]+$ ]]; then
            suggested=$(slugify "${POSITIONAL:0:50}")
        fi

        OUTPUT_FILE="${AIT_OUTPUT_DIR}/exec-comms/${suggested}.md"
        mkdir -p "$(dirname "$OUTPUT_FILE")"
        printf '%s\n' "$content" > "$OUTPUT_FILE"
        echo "Saved: $OUTPUT_FILE" >&2
    else
        prompt="${prompt}

---

IMPORTANT: This is an async task. Output the FIR-formatted communication directly. Do not ask for clarification or confirmation. Make reasonable assumptions where needed."

        run_llm "$prompt" "$OUTPUT_FILE"
    fi
}

