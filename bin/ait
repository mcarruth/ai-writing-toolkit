#!/usr/bin/env bash
set -euo pipefail

# --- Constants ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILLS_DIR="$REPO_ROOT/skills"

# --- Defaults ---
DEFAULT_BACKEND="kiro"
DEFAULT_MODEL_CLAUDE="claude-sonnet-4-6"
DEFAULT_MODEL_KIRO="claude-sonnet-4.5"

# --- Config ---
AIT_CONFIG_FILE="$HOME/.ait/config"

read_config_val() {
    local key="$1"
    if [[ -f "$AIT_CONFIG_FILE" ]]; then
        local val
        val=$(grep "^${key}=" "$AIT_CONFIG_FILE" 2>/dev/null | cut -d= -f2- || true)
        # Strip surrounding single or double quotes (e.g. output_dir="/path with spaces")
        val="${val#\"}" ; val="${val%\"}"
        val="${val#\'}" ; val="${val%\'}"
        printf '%s' "$val"
    fi
}

load_config() {
    local val
    val=$(read_config_val output_dir)
    val="${val/#\~/$HOME}"
    AIT_OUTPUT_DIR="${AIT_OUTPUT_DIR:-$val}"
    AIT_BACKEND="${AIT_BACKEND:-$(read_config_val backend)}"
    AIT_BACKEND="${AIT_BACKEND:-$DEFAULT_BACKEND}"
    AIT_MODEL="${AIT_MODEL:-$(read_config_val model)}"
    if [[ -z "$AIT_MODEL" ]]; then
        case "$AIT_BACKEND" in
            kiro)        AIT_MODEL="$DEFAULT_MODEL_KIRO" ;;
            claude-code) AIT_MODEL="$DEFAULT_MODEL_CLAUDE" ;;
            *)           AIT_MODEL="$DEFAULT_MODEL_CLAUDE" ;;
        esac
    fi
}

load_config

# --- Shared functions ---

require_backend() {
    case "$AIT_BACKEND" in
        kiro)
            if ! command -v kiro-cli &>/dev/null; then
                echo "Error: kiro-cli not found (backend=kiro)." >&2
                echo "Install: npm install -g @amazon/kiro-cli" >&2
                echo "Or switch backend: ait config backend claude-code" >&2
                exit 1
            fi
            ;;
        claude-code)
            if ! command -v claude &>/dev/null; then
                echo "Error: claude not found (backend=claude-code)." >&2
                echo "Install: npm install -g @anthropic-ai/claude-code" >&2
                echo "Or switch backend: ait config backend kiro" >&2
                exit 1
            fi
            ;;
        custom)
            local cmd
            cmd=$(read_config_val custom_command)
            if [[ -z "$cmd" ]]; then
                echo "Error: backend=custom but no custom_command configured." >&2
                echo "Set it: ait config custom-command 'your-cli --flags'" >&2
                exit 1
            fi
            ;;
        *)
            echo "Error: unknown backend '$AIT_BACKEND'." >&2
            echo "Supported: kiro, claude-code, custom" >&2
            exit 1
            ;;
    esac
}

load_skill() {
    local shared="$SKILLS_DIR/_shared/amazon-writing.md"
    local skill="$SKILLS_DIR/$1/SKILL.md"
    if [[ ! -f "$skill" ]]; then
        echo "Error: skill not found: $1" >&2
        exit 1
    fi
    SHARED_CONTENT=$(cat "$shared")
    SKILL_CONTENT=$(cat "$skill")
}

append_context() {
    local prompt="$1"
    shift
    for ctx in "$@"; do
        if [[ ! -f "$ctx" ]] && [[ -n "${AIT_OUTPUT_DIR:-}" ]] && [[ "$ctx" == "$(basename "$ctx")" ]]; then
            local match_count match_path
            match_count=$(find "$AIT_OUTPUT_DIR" -name "$ctx" -type f | wc -l | tr -d ' ')
            if [[ "$match_count" -eq 1 ]]; then
                match_path=$(find "$AIT_OUTPUT_DIR" -name "$ctx" -type f)
                ctx="$match_path"
            elif [[ "$match_count" -gt 1 ]]; then
                echo "Warning: ambiguous context file '$ctx' — multiple matches in output-dir, skipping:" >&2
                find "$AIT_OUTPUT_DIR" -name "$ctx" -type f | sed 's/^/  /' >&2
                continue
            fi
        fi
        if [[ ! -f "$ctx" ]]; then
            echo "Warning: context file not found: $ctx" >&2
            continue
        fi
        prompt="${prompt}

--- Context: $(basename "$ctx") ---
$(cat "$ctx")
--- End Context ---"
    done
    printf '%s' "$prompt"
}

capture_llm() {
    local prompt="$1"
    local tmpfile
    tmpfile=$(mktemp /tmp/ait-XXXXXX.txt)
    printf '%s\n' "$prompt" > "$tmpfile"
    run_backend "$tmpfile"
    rm -f "$tmpfile"
}

run_llm() {
    local prompt="$1"
    local output_file="$2"

    AIT_TMPFILE=$(mktemp /tmp/ait-XXXXXX.txt)
    trap 'rm -f "$AIT_TMPFILE"' EXIT
    printf '%s\n' "$prompt" > "$AIT_TMPFILE"

    if [[ -n "$output_file" ]]; then
        # Buffer full output before writing — streaming writes to Google Drive FUSE time out
        local output
        output=$(run_backend "$AIT_TMPFILE")
        mkdir -p "$(dirname "$output_file")"
        printf '%s\n' "$output" > "$output_file"
        echo "Saved: $output_file" >&2
    else
        run_backend "$AIT_TMPFILE"
    fi
}

run_backend() {
    local infile="$1"
    case "$AIT_BACKEND" in
        kiro)
            cat "$infile" \
                | kiro-cli chat --no-interactive --trust-all-tools --wrap never --model "$AIT_MODEL" 2>&1 \
                | perl -pe 's/\x1b\[[0-9;?]*[a-zA-Z]//g; s/^(?:---)?(?:\xe2\x94\x81)+$/---/' \
                | grep -v "^Running tool " \
                | grep -v "^ ⋮" \
                | grep -v "^ - Completed in" \
                | grep -v "^ ✓ " \
                | grep -v "^↱ " \
                | grep -v "Credits: [0-9]" \
                | sed '/^$/N;/^\n$/d'
            ;;
        claude-code)
            claude -p --model "$AIT_MODEL" < "$infile" 2>/dev/null
            ;;
        custom)
            local cmd
            cmd=$(read_config_val custom_command)
            eval "$cmd" < "$infile" 2>/dev/null
            ;;
    esac
}

resolve_positional() {
    # If POSITIONAL is an existing file, read its contents as the input and
    # record the basename for use in filename generation.
    POSITIONAL_NAME="$POSITIONAL"
    if [[ -f "$POSITIONAL" ]]; then
        POSITIONAL_NAME=$(basename "$POSITIONAL")
        POSITIONAL_NAME="${POSITIONAL_NAME%.*}"
        POSITIONAL=$(cat "$POSITIONAL")
    fi
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | sed 's/^-//;s/-$//'
}

generate_filename() {
    local topic="$1" type="$2"
    local prompt="Output a single kebab-case filename (3-5 words, lowercase letters and hyphens only, no extension) that describes this ${type} document about: ${topic}
Output in this exact format: FILENAME: my-doc-name"
    local raw suggested
    raw=$(capture_llm "$prompt")
    suggested=$(printf '%s\n' "$raw" | sed 's/^[> ]*//' | grep '^FILENAME:' | head -1 | sed 's/^FILENAME:[[:space:]]*//' | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9-' '-' | sed 's/^-*//;s/-*$//')
    if [[ ! "$suggested" =~ ^[a-z0-9][a-z0-9-]*$ ]] || [[ -z "$suggested" ]]; then
        local full_slug
        full_slug=$(slugify "$topic")
        suggested=$(printf '%s' "$full_slug" | cut -c1-55 | sed 's/-[^-]*$//')
        [[ -z "$suggested" ]] && suggested=$(printf '%s' "$full_slug" | cut -c1-55)
    fi
    printf '%s' "$suggested"
}

resolve_output() {
    local cmd="$1" topic="$2"
    if [[ "$OUTPUT_FILE" == */ ]]; then
        # Trailing slash: treat as directory, append slugified topic
        OUTPUT_FILE="${OUTPUT_FILE}$(slugify "$topic").md"
    elif [[ -z "$OUTPUT_FILE" ]]; then
        # No -o flag: auto-generate path under output-dir
        [[ -n "${AIT_OUTPUT_DIR:-}" ]] && OUTPUT_FILE="${AIT_OUTPUT_DIR}/${cmd}/$(slugify "$topic").md"
    elif [[ -n "${AIT_OUTPUT_DIR:-}" ]] && [[ "$OUTPUT_FILE" == "$(basename "$OUTPUT_FILE")" ]]; then
        # Bare filename (no directory component): prepend output-dir/cmd/
        local fname="$OUTPUT_FILE"
        [[ "$fname" != *.* ]] && fname="${fname}.md"
        OUTPUT_FILE="${AIT_OUTPUT_DIR}/${cmd}/${fname}"
    fi
}

parse_context_and_output() {
    CONTEXT_FILES=()
    OUTPUT_FILE=""
    POSITIONAL=""
    local -a _positionals=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --context|-c)
                local cpath="$2"
                shift 2
                # Reconstruct path with spaces: consume non-flag args until file found
                while [[ $# -gt 0 ]] && [[ "$1" != -* ]] && [[ ! -f "$cpath" ]]; do
                    cpath="$cpath $1"
                    shift
                done
                CONTEXT_FILES+=("$cpath")
                ;;
            --output|-o)
                local opath="$2"
                shift 2
                # Reconstruct path with spaces: consume non-flag args until a file extension is found
                while [[ $# -gt 0 ]] && [[ "$1" != -* ]] && [[ ! "$opath" =~ \.[a-zA-Z0-9]{1,5}$ ]]; do
                    opath="$opath $1"
                    shift
                done
                OUTPUT_FILE="$opath"
                ;;
            --model|-m)
                AIT_MODEL="$2"
                shift 2
                ;;
            --help|-h) return 1 ;;
            -*) echo "Unknown flag: $1" >&2; return 1 ;;
            *)
                _positionals+=("$1")
                shift
                ;;
        esac
    done

    # Join all positional words — reconstructs unquoted paths with spaces, and
    # allows multi-word text args (e.g. ait write hld my raw notes) without quoting
    POSITIONAL="${_positionals[*]+"${_positionals[*]}"}"
}


validate_frontmatter() {
    local file="$1"
    local required=(topic date type status version tags)
    local missing=()
    for key in "${required[@]}"; do
        if ! grep -qE "^${key}:" "$file" 2>/dev/null; then
            missing+=("$key")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Warning: front matter missing required field(s): ${missing[*]}" >&2
    fi
}

generate_frontmatter() {
    local topic_input="$1" type="$2"
    local prompt="Generate YAML front matter fields for a ${type} document. The document is about: ${topic_input}

Output exactly two lines, nothing else:
topic: \"Short descriptive title, 5-8 words max, in title case\"
tags: [kebab-case-tag, another-tag, up-to-six-tags]"
    local raw topic_line tags_line
    raw=$(capture_llm "$prompt")
    topic_line=$(printf '%s\n' "$raw" | sed 's/^[> ]*//' | grep '^topic:' | head -1)
    tags_line=$(printf '%s\n' "$raw" | sed 's/^[> ]*//' | grep '^tags:' | head -1)
    if [[ -z "$topic_line" ]]; then
        # Convert slug fallback (e.g. "context-window-accuracy") to title case
        local title
        title=$(printf '%s' "$topic_input" | tr '-' ' ' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2); print}')
        topic_line="topic: \"${title}\""
    fi
    [[ -z "$tags_line" ]] && tags_line="tags: []"
    printf '%s\n%s\n' "$topic_line" "$tags_line"
}

run_llm_named() {
    local prompt="$1" type="$2" explicit_output="$3"

    local body_prompt="${prompt}

---

IMPORTANT: This is an async task. Output the document body as raw markdown. Start directly with the first section heading. Do not include YAML front matter. Do not wrap in a code fence. Do not ask for clarification or confirmation. Where information is missing, make a reasonable assumption and call it out explicitly."

    # Determine output path
    local out_file="$explicit_output"
    local suggested=""
    if [[ -z "$out_file" ]] && [[ -n "${AIT_OUTPUT_DIR:-}" ]]; then
        suggested=$(generate_filename "$POSITIONAL_NAME" "$type")
        out_file="${AIT_OUTPUT_DIR}/${type}/${suggested}.md"
    elif [[ -n "$out_file" ]]; then
        # Derive a short hint from the explicit output filename for front matter
        suggested=$(basename "$out_file")
        suggested="${suggested%.*}"
    fi

    if [[ -n "$out_file" ]]; then
        # Generate front matter fields via a separate focused LLM call.
        # Pass the short filename (e.g. "context-window-accuracy") as the hint
        # so the LLM produces a concise title instead of echoing the full prompt.
        local fm_hint="${suggested:-$POSITIONAL_NAME}"
        local fm_lines today context_field yaml
        fm_lines=$(generate_frontmatter "$fm_hint" "$type")
        today=$(date +%Y-%m-%d)

        # Build context field from known context files
        context_field=""
        if [[ ${#CONTEXT_FILES[@]} -gt 0 ]]; then
            local ctx_items="" ctx name
            for ctx in "${CONTEXT_FILES[@]}"; do
                name=$(basename "$ctx"); name="${name%.*}"
                ctx_items="${ctx_items}\"[[${name}]]\", "
            done
            context_field=$'\n'"context: [${ctx_items%, }]"
        fi

        yaml="${fm_lines}
date: ${today}
type: ${type}
status: Draft
version: \"1.0\"${context_field}"

        # Generate body — front matter is handled separately so LLM only writes content
        local body
        body=$(capture_llm "$body_prompt")

        # Strip anything before the first heading (kiro noise, code fences, stray front matter)
        body=$(printf '%s\n' "$body" | awk '/^#/{found=1} found{print}')

        mkdir -p "$(dirname "$out_file")"
        { printf -- '---\n'; printf '%s\n' "$yaml"; printf -- '---\n'; printf '%s\n' "$body"; } > "$out_file"
        validate_frontmatter "$out_file"
        echo "Saved: $out_file" >&2
    else
        run_llm "$body_prompt" ""
    fi
}

# --- Subcommand: research ---

cmd_research() {
    local usage="Usage: ait research <topic> [-c <file>]... [-o <file>]

  <topic>           Topic to research (quote multi-word topics)
  -c, --context     Inject a context file (repeatable)
  -o, --output      Write output to file (default: stdout)

Examples:
  ait research \"transformer attention mechanisms\"
  ait research \"LLM agent memory architectures\" -o research.md
  ait research \"vector DB tradeoffs\" -c requirements.md"

    parse_context_and_output "$@" || { echo "$usage" >&2; exit 1; }
    if [[ -z "$POSITIONAL" ]]; then echo "$usage" >&2; exit 1; fi
    resolve_positional

    local explicit_output="$OUTPUT_FILE"
    resolve_output "research" "$POSITIONAL_NAME"

    load_skill "research"
    local prompt="${SHARED_CONTENT}

---

${SKILL_CONTENT}

---

Topic: ${POSITIONAL}"

    prompt=$(append_context "$prompt" "${CONTEXT_FILES[@]+"${CONTEXT_FILES[@]}"}")
    run_llm_named "$prompt" "research" "$explicit_output"
}

# --- Subcommand: design-options ---

cmd_design_options() {
    local usage="Usage: ait design-options <problem-statement> [-c <file>]... [-o <file>]

  <problem-statement>  What you need to design (quote it)
  -c, --context        Inject a context file (repeatable)
  -o, --output         Write output to file (default: stdout)

Examples:
  ait design-options \"how to store conversation history for LLM agents at 10k RPS\"
  ait design-options \"sub-agent memory scoping\" -c research.md -o design-options.md"

    parse_context_and_output "$@" || { echo "$usage" >&2; exit 1; }
    if [[ -z "$POSITIONAL" ]]; then echo "$usage" >&2; exit 1; fi
    resolve_positional

    local explicit_output="$OUTPUT_FILE"
    resolve_output "design-options" "$POSITIONAL_NAME"

    load_skill "design-options"
    local prompt="${SHARED_CONTENT}

---

${SKILL_CONTENT}

---

Problem statement: ${POSITIONAL}"

    prompt=$(append_context "$prompt" "${CONTEXT_FILES[@]+"${CONTEXT_FILES[@]}"}")
    run_llm_named "$prompt" "design-options" "$explicit_output"
}

# --- Subcommand: write ---

_write_doc() {
    local type="$1" label="$2"
    shift 2

    local usage="Usage: ait write ${type} <${label}> [-c <file>]... [-o <file>]

  <${label}>    Your notes or description (quote multi-word input)
  -c, --context     Inject a context file (repeatable)
  -o, --output      Write output to file (default: stdout)

Examples:
  ait write ${type} \"your notes here\"
  ait write ${type} \"your notes\" -c context.md -o output.md"

    parse_context_and_output "$@" || { echo "$usage" >&2; exit 1; }
    if [[ -z "$POSITIONAL" ]]; then echo "$usage" >&2; exit 1; fi
    resolve_positional

    local explicit_output="$OUTPUT_FILE"
    resolve_output "$type" "$POSITIONAL_NAME"

    load_skill "${type}/write"
    local prompt="${SHARED_CONTENT}

---

${SKILL_CONTENT}

---

${label}: ${POSITIONAL}"

    prompt=$(append_context "$prompt" "${CONTEXT_FILES[@]+"${CONTEXT_FILES[@]}"}")
    run_llm_named "$prompt" "$type" "$explicit_output"
}

cmd_write() {
    local type="${1:-}"
    if [[ -z "$type" ]]; then
        echo "Usage: ait write <type> [options]" >&2
        echo "" >&2
        echo "Types:" >&2
        echo "  hld          High-level design document" >&2
        echo "  prfaq        Press release and FAQ (Working Backwards)" >&2
        echo "  six-pager    Six-page narrative for leadership review" >&2
        echo "  one-pager    One-page summary for stakeholders" >&2
        echo "  coe          Correction of Errors" >&2
        echo "  op1          Operating Plan narrative" >&2
        echo "  mbr          Monthly Business Review narrative" >&2
        exit 1
    fi
    shift

    case "$type" in
        hld)        _write_doc "hld" "Engineer's notes and intent" "$@" ;;
        prfaq)      _write_doc "prfaq" "Product idea and customer problem" "$@" ;;
        six-pager)  _write_doc "six-pager" "Raw notes and context" "$@" ;;
        one-pager)  _write_doc "one-pager" "Topic or prompt" "$@" ;;
        coe)        _write_doc "coe" "Incident notes and timeline" "$@" ;;
        op1)        _write_doc "op1" "Team goals and investment asks" "$@" ;;
        mbr)        _write_doc "mbr" "Month's results and asks" "$@" ;;
        --help|-h)
            cmd_write
            ;;
        *)
            echo "Unknown type: $type" >&2
            echo "Types: hld, prfaq, six-pager, one-pager, coe, op1, mbr" >&2
            exit 1
            ;;
    esac
}

# --- Subcommand: review ---

_review_doc() {
    local type="$1"
    shift

    local usage="Usage: ait review ${type} <file> [-c <file>]... [-o <file>]

  <file>            Path to the ${type} markdown file to review
  -c, --context     Inject a context file (repeatable)
  -o, --output      Write output to file (default: stdout)

Examples:
  ait review ${type} ${type}.md
  ait review ${type} ${type}.md -c context.md"

    parse_context_and_output "$@" || { echo "$usage" >&2; exit 1; }
    if [[ -z "$POSITIONAL" ]]; then echo "$usage" >&2; exit 1; fi
    if [[ ! -f "$POSITIONAL" ]]; then
        echo "Error: file not found: $POSITIONAL" >&2
        exit 1
    fi
    if ! file "$POSITIONAL" | grep -q "text"; then
        echo "Error: $POSITIONAL does not appear to be a text file. Only plain text and markdown files are supported." >&2
        exit 1
    fi

    local basename
    basename=$(basename "$POSITIONAL")
    basename="${basename%.*}"
    resolve_output "$type" "${basename}-review"

    load_skill "${type}/review"
    local prompt="${SHARED_CONTENT}

---

${SKILL_CONTENT}

---

Document to review:

$(cat "$POSITIONAL")"

    prompt=$(append_context "$prompt" "${CONTEXT_FILES[@]+"${CONTEXT_FILES[@]}"}")
    prompt="${prompt}

---

IMPORTANT: This is an async task. Output the review directly. Do not ask for clarification or confirmation."

    run_llm "$prompt" "$OUTPUT_FILE"
}

cmd_review() {
    local type="${1:-}"
    if [[ -z "$type" ]]; then
        echo "Usage: ait review <type> <file> [options]" >&2
        echo "" >&2
        echo "Types:" >&2
        echo "  hld          High-level design document" >&2
        echo "  prfaq        Press release and FAQ" >&2
        echo "  six-pager    Six-page narrative for leadership review" >&2
        echo "  one-pager    One-page summary for stakeholders" >&2
        echo "  coe          Correction of Errors" >&2
        echo "  op1          Operating Plan narrative" >&2
        echo "  mbr          Monthly Business Review narrative" >&2
        exit 1
    fi
    shift

    case "$type" in
        hld|prfaq|six-pager|one-pager|coe|op1|mbr) _review_doc "$type" "$@" ;;
        --help|-h)
            cmd_review
            ;;
        *)
            echo "Unknown type: $type" >&2
            echo "Types: hld, prfaq, six-pager, one-pager, coe, op1, mbr" >&2
            exit 1
            ;;
    esac
}

# --- Subcommand: config ---

cmd_config() {
    local usage="Usage: ait config <key> [value]

Keys:
  output-dir [path]         Default output directory
  backend [name]            LLM backend: kiro, claude-code, custom
  model [name]              Model name (default: claude-sonnet-4.6)
  custom-command [cmd]      Shell command for custom backend (reads stdin)

Use --clear to remove a value.

Examples:
  ait config backend claude-code
  ait config model claude-sonnet-4-20250514
  ait config output-dir ~/work/ait
  ait config custom-command 'my-llm-cli --no-interactive'"

    if [[ $# -eq 0 ]]; then
        local b m o c
        b=$(read_config_val backend); m=$(read_config_val model)
        o=$(read_config_val output_dir); c=$(read_config_val custom_command)
        echo "backend:    ${b:-<not set>} (default: $DEFAULT_BACKEND)"
        echo "model:      ${m:-<not set>} (default: $AIT_MODEL)"
        echo "output-dir: ${o:-<not set>}"
        echo "custom-cmd: ${c:-<not set>}"
        return 0
    fi

    local key="$1"
    local config_key

    case "$key" in
        output-dir)      config_key="output_dir" ;;
        backend)         config_key="backend" ;;
        model)           config_key="model" ;;
        custom-command)  config_key="custom_command" ;;
        *) echo "$usage" >&2; exit 1 ;;
    esac

    mkdir -p "$(dirname "$AIT_CONFIG_FILE")"
    touch "$AIT_CONFIG_FILE"

    if [[ $# -eq 1 ]]; then
        local val
        val=$(read_config_val "$config_key")
        echo "${val:-<not set>}"
    elif [[ "$2" == "--clear" ]]; then
        python3 -c "
import re
content = open('$AIT_CONFIG_FILE').read()
content = re.sub(r'^${config_key}=.*\n?', '', content, flags=re.MULTILINE)
open('$AIT_CONFIG_FILE', 'w').write(content)
"
        echo "${key} cleared."
    else
        if grep -q "^${config_key}=" "$AIT_CONFIG_FILE" 2>/dev/null; then
            AIT_CONFIG_KEY="${config_key}" AIT_CONFIG_VAL="$2" python3 -c "
import re, os
key = os.environ['AIT_CONFIG_KEY']
val = os.environ['AIT_CONFIG_VAL']
content = open('$AIT_CONFIG_FILE').read()
content = re.sub(r'^' + re.escape(key) + r'=.*', key + '=' + val, content, flags=re.MULTILINE)
open('$AIT_CONFIG_FILE', 'w').write(content)
"
        else
            echo "${config_key}=$2" >> "$AIT_CONFIG_FILE"
        fi
        echo "${key} set to $2"
        # When backend changes, clear model so the backend-aware default takes effect
        if [[ "$key" == "backend" ]]; then
            python3 -c "
import re
content = open('$AIT_CONFIG_FILE').read()
content = re.sub(r'^model=.*\n?', '', content, flags=re.MULTILINE)
open('$AIT_CONFIG_FILE', 'w').write(content)
"
            echo "model cleared (will use default for $2)"
        fi
    fi
}

# --- Main dispatcher ---

main_usage() {
    cat >&2 <<EOF
ait — AI Writing Toolkit

Usage: ait <command> [options]

Commands:
  research          Research brief on any topic
  design-options    Three differentiated architectural options

  write <type>      Draft a document
    hld             High-level design document
    prfaq           Press release and FAQ (Working Backwards)
    six-pager       Six-page narrative for leadership review
    one-pager       One-page summary for stakeholders
    coe             Correction of Errors
    op1             Operating Plan narrative
    mbr             Monthly Business Review narrative

  review <type>     VP-level review of a document
    hld             High-level design document
    prfaq           Press release and FAQ
    six-pager       Six-page narrative for leadership review
    one-pager       One-page summary for stakeholders
    coe             Correction of Errors
    op1             Operating Plan narrative
    mbr             Monthly Business Review narrative

  config            View or set configuration

Common flags:
  -c, --context <file>   Inject a context file (repeatable)
  -o, --output <file>    Write output to file (default: stdout)
  -m, --model <name>     Override model for this invocation
  -h, --help             Show help

Backend: $AIT_BACKEND (model: $AIT_MODEL)
  Change with: ait config backend <kiro|claude-code|custom>

Examples:
  ait research "agent memory architectures" -o research.md
  ait design-options "memory scoping" -c research.md -o design-options.md
  ait write hld "going with option 2" -c research.md -c design-options.md
  ait review hld hld.md -c research.md
EOF
    exit 1
}

if [[ $# -eq 0 ]]; then
    main_usage
fi

COMMAND="$1"
shift

case "$COMMAND" in
    research)        require_backend; cmd_research "$@" ;;
    design-options)  require_backend; cmd_design_options "$@" ;;
    write)           require_backend; cmd_write "$@" ;;
    review)          require_backend; cmd_review "$@" ;;
    config)          cmd_config "$@" ;;
    --help|-h)       main_usage ;;
    *) echo "Unknown command: $COMMAND" >&2; echo "" >&2; main_usage ;;
esac
